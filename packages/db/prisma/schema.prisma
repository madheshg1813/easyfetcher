generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
  ENTERPRISE
}

enum Platform {
  GSC
  GA4
  GOOGLE_ADS
  META_ADS
  REDDIT_ADS
  SHOPIFY
  BING_ADS
  INSTAGRAM
  LINKEDIN_ADS
  GOOGLE_MY_BUSINESS
  TIKTOK_ADS
  GOOGLE_TRENDS
  YOUTUBE
  YOUTUBE_ADS
  PSI
}

enum SeoJobType {
  KEYWORD_RANK
  BACKLINK
  GEO_VISIBILITY
  SITE_AUDIT
  DOMAIN_RATING
}

enum SeoJobStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}

enum CheckSchedule {
  MANUAL
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum CreditTxType {
  PLAN_GRANT
  PURCHASE
  KEYWORD_RANK
  BACKLINK
  GEO_VISIBILITY
  SITE_AUDIT
  DOMAIN_RATING
  REFUND
}

enum PromptCategory {
  SEO
  ANALYTICS
  PAID_ADS
  SOCIAL
  ECOMMERCE
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

model User {
  id                String        @id @default(cuid())
  clerkId           String        @unique
  email             String        @unique
  name              String?
  plan              Plan          @default(FREE)
  apiKey            String        @unique @default(cuid())
  onboarded         Boolean       @default(false)
  activeWorkspaceId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  workspaces          Workspace[]
  connections         Connection[]
  promptRuns          PromptRun[]
  subscription        Subscription?
  activityLogs        ActivityLog[]
  oauthCodes          OAuthCode[]
  pendingConnections  PendingConnection[]
  keywordLists        KeywordList[]
  keywordSnapshots    KeywordSnapshot[]
  seoJobs             SeoJob[]
  userCredit          UserCredit?
  creditTransactions  CreditTransaction[]
}

model Workspace {
  id          String       @id @default(cuid())
  userId      String
  name        String
  slug        String       // URL-safe, used in MCP tool names — immutable after creation
  websiteUrl  String?
  faviconUrl  String?
  isDefault   Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections Connection[]
  pendingConnections PendingConnection[]

  @@unique([userId, slug])
}

model OAuthClient {
  id           String   @id @default(cuid())
  clientId     String   @unique
  redirectUris String[]
  clientName   String?
  createdAt    DateTime @default(now())
}

model OAuthCode {
  id          String   @id @default(cuid())
  code        String   @unique
  clientId    String
  userId      String
  redirectUri String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Connection {
  id            String           @id @default(cuid())
  userId        String
  workspaceId   String?
  platform      Platform
  accessToken   String           // AES-256 encrypted
  refreshToken  String?          // AES-256 encrypted
  expiresAt     DateTime?
  status        ConnectionStatus @default(CONNECTED)
  siteUrl       String?          // for GSC — one Connection per site
  accountId     String?          // for ads/GA4 platforms
  label         String?          // user-friendly name e.g. "getgowns.com"
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform, siteUrl])
}

// Temporarily holds OAuth tokens between Google callback and site selection
model PendingConnection {
  id           String    @id @default(cuid())
  userId       String
  workspaceId  String?
  platform     Platform
  accessToken  String    // AES-256 encrypted
  refreshToken String?   // AES-256 encrypted
  tokenExpiry  DateTime?
  sites        Json      // array of { siteUrl, permissionLevel } for GSC / { name, displayName } for GA4
  userEmail    String?
  expiresAt    DateTime  // this pending record expires in 15 min
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Prompt {
  id              String         @id @default(cuid())
  title           String
  description     String
  category        PromptCategory
  requiredSources Platform[]
  requiredPlan    Plan           @default(FREE)
  template        String         @db.Text
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  runs            PromptRun[]
}

model PromptRun {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // CONNECTED, DISCONNECTED, PROMPT_RUN, TOKEN_REFRESH, KEY_ROTATED
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  stripeCustomerId   String   @unique
  stripePriceId      String
  stripeSubId        String   @unique
  status             String
  currentPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SEO Tools ────────────────────────────────────────────────────────────────

// Saved keyword lists per domain — managed from /app/seo/rank-tracker dashboard
model KeywordList {
  id        String            @id @default(cuid())
  userId    String
  domain    String            // e.g. "easyfetcher.com" (no protocol)
  name      String            // e.g. "Priority Keywords", "Brand Terms"
  keywords  String[]          // PostgreSQL native array
  tags      String[]          // e.g. ["brand", "competitor", "long-tail"]
  location      String        @default("United States")
  device        String        @default("desktop")
  schedule      CheckSchedule @default(MANUAL)
  lastCheckedAt DateTime?
  nextCheckAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots     KeywordSnapshot[]

  @@index([userId, domain])
}

// One row per keyword per check — drives rank history graphs and change detection
model KeywordSnapshot {
  id            String      @id @default(cuid())
  userId        String
  keywordListId String?
  seoJobId      String?
  domain        String
  keyword       String
  location      String      @default("United States")
  device        String      @default("desktop")
  rank          Int?        // null = not ranked in top 50
  rankUrl       String?     // URL that ranked for this keyword
  rankTitle     String?     // <title> of the ranking page
  pagesChecked  Int         @default(1)  // 1–5 SERP pages checked
  checkedAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywordList   KeywordList? @relation(fields: [keywordListId], references: [id], onDelete: SetNull)
  seoJob        SeoJob?     @relation(fields: [seoJobId], references: [id], onDelete: SetNull)

  @@index([userId, domain, keyword, checkedAt])
  @@index([userId, checkedAt])
}

// Tracks async Apify runs — MCP tool polls this until status = DONE
model SeoJob {
  id            String        @id @default(cuid())
  userId        String
  type          SeoJobType
  status        SeoJobStatus  @default(PENDING)
  domain        String
  input         Json          // what was requested (keywords, location, device, etc.)
  result        Json?         // filtered payload returned to Claude
  creditsUsed   Int           @default(0)
  apifyRunId    String?       // Apify run ID for polling
  errorMsg      String?
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots     KeywordSnapshot[]

  @@index([userId, status])
  @@index([userId, type, startedAt])
}

// ─── Credits ──────────────────────────────────────────────────────────────────

// Current credit balance per user — single row, updated on each transaction
model UserCredit {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Full audit trail — positive = grant/purchase, negative = spend
model CreditTransaction {
  id          String       @id @default(cuid())
  userId      String
  amount      Int          // positive = added, negative = spent
  type        CreditTxType
  referenceId String?      // SeoJob.id for spends
  note        String?      // e.g. "Plan grant: PRO monthly reset"
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
