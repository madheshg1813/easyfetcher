# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook secret — set up in Clerk Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/webhooks/clerk
# Events to subscribe: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Get from Supabase Dashboard → Settings → Database → Connection String
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Use the direct connection URL for DIRECT_URL (port 5432) — used for migrations
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — set up in Stripe Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/stripe/webhook
# Events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — get from Stripe Dashboard → Products
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=price_...

# ─── Upstash Redis (Rate Limiting) ───────────────────────────────────────────
# Get from https://console.upstash.com → Redis → your database → REST API
UPSTASH_REDIS_REST_URL=https://[your-db-id].upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_...

# ─── Token Encryption ────────────────────────────────────────────────────────
# 32-byte (256-bit) hex key for AES-256 encryption of OAuth tokens
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=...

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/callback/google
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/callback/google

# ─── Meta (Facebook/Instagram) ───────────────────────────────────────────────
# Get from https://developers.facebook.com → My Apps → your app → Settings → Basic
# Authorized redirect URI: http://localhost:3000/api/callback/meta
META_APP_ID=...
META_APP_SECRET=...
META_REDIRECT_URI=http://localhost:3000/api/callback/meta

# ─── Shopify OAuth ───────────────────────────────────────────────────────────
# Create a Shopify Partner app at https://partners.shopify.com → Apps → Create app
# Allowed redirect URI: {NEXT_PUBLIC_APP_URL}/api/callback/shopify
SHOPIFY_CLIENT_ID=...
SHOPIFY_CLIENT_SECRET=...
