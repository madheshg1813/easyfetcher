# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook secret — set up in Clerk Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/webhooks/clerk
# Events to subscribe: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Get from Supabase Dashboard → Settings → Database → Connection String
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543)
#DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Use the direct connection URL for DIRECT_URL (port 5432) — used for migrations
#DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres


# ─── Database (Neon) ─────────────────────────────────────────────────────────
# Get from Neon Dashboard → your project → Connection Details
# Pooler URL for DATABASE_URL — add pgbouncer=true for Prisma compatibility
DATABASE_URL=postgresql://[user]:[password]@[endpoint]-pooler.[region].aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# Direct (non-pooler) URL for DIRECT_URL — used for Prisma migrations
DIRECT_URL=postgresql://[user]:[password]@[endpoint].[region].aws.neon.tech/neondb?sslmode=require

# ─── Dodo Payments ────────────────────────────────────────────────────────────────
# Get your API key from https://dashboard.dodopayments.com
DODO_API_KEY=...
DODO_API_MODE=live # or "test" for Dodo test mode

# Webhook secret — set up in Dodo Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/webhooks/dodo
# Events: subscription.active, subscription.cancelled, subscription.expired, payment.succeeded
DODO_WEBHOOK_SECRET=...

# Product IDs from Dodo Dashboard → Products
NEXT_PUBLIC_DODO_STARTER_YEARLY_ID=pdt_0Ng5wo22oONBlqDIQvQQH
NEXT_PUBLIC_DODO_PRO_YEARLY_ID=pdt_0Ng5xPsUKdHXhvmQOsEz9
NEXT_PUBLIC_DODO_AGENCY_YEARLY_ID=pdt_0Ng5xi9BNGdxE9t2akkwK
NEXT_PUBLIC_DODO_STARTER_MONTHLY_ID=pdt_0Ng5y8DYr4SO7bAbztKe1
NEXT_PUBLIC_DODO_PRO_MONTHLY_ID=pdt_0Ng5yT8aBWnSvfhryKLOC
NEXT_PUBLIC_DODO_AGENCY_MONTHLY_ID=pdt_0Ng5ykFTysYI4D73Jx37I

# ─── Upstash Redis (Rate Limiting) ───────────────────────────────────────────
# Get from https://console.upstash.com → Redis → your database → REST API
UPSTASH_REDIS_REST_URL=https://[your-db-id].upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_...

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte (256-bit) key for AES-256 encryption of OAuth tokens
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=...

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI must be: {NEXT_PUBLIC_APP_URL}/api/callback/google
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ─── App ─────────────────────────────────────────────────────────────────────
# Set to your production URL in Vercel (e.g. https://hub-beta.easyfetcher.com)
# The Google OAuth redirect URI is derived from this automatically — no separate GOOGLE_REDIRECT_URI needed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google PageSpeed Insights API ───────────────────────────────────────────
# Enable the PageSpeed Insights API in Google Cloud Console:
# https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
# Then create an API key under APIs & Services → Credentials
PAGESPEED_API_KEY=...
