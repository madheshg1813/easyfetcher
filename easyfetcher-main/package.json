{
  "name": "easyfetcher",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter @easyfetcher/db db:generate",
    "db:migrate": "pnpm --filter @easyfetcher/db db:migrate",
    "db:push": "pnpm --filter @easyfetcher/db db:push",
    "db:seed": "pnpm --filter @easyfetcher/db db:seed",
    "db:studio": "pnpm --filter @easyfetcher/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
